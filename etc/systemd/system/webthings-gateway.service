[Unit]
Description=Candle Controller Client
After=network.target candle_early.service dbus.service
#Requires=dbus-setenv.service
Requires=dbus.service
#OnFailure=webthings-gateway.update-rollback.service
ConditionPathExists=/boot/firmware/candle_first_run_complete.txt
ConditionPathExists=!/boot/firmware/candle_disabled.txt
StartLimitInterval=0
StartLimitIntervalSec=0
StartLimitBurst=0

[Service]
Type=simple
#StandardOutput=journal
StandardOutput=null
StandardError=journal
User=pi
WorkingDirectory=/home/pi/webthings/gateway
# Edit this line, if needed, to set the correct path to node
ExecStart=/home/pi/webthings/gateway/candle_controller.sh
Restart=always
RestartSec=10s

[Install]
WantedBy=multi-user.target
