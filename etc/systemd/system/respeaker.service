[Unit]
Description=Seeed Voicecard service
After=etc-hostname.mount etc-ssh.mount alsa-restore.service
ConditionPathExists=/boot/firmware/candle_respeaker.txt
ConditionPathExists=/usr/bin/seeed-voicecard
 
[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/bin/seeed-voicecard
User=root
 
[Install]
WantedBy=sysinit.target
